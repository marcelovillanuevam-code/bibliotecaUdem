{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=biblioteca_udem;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "BibliotecaUdem",
    "Audience": "BibliotecaUdem.Client",
    "ExpiresInMinutes": 60
  },
  "Auth": {
    "AllowedEmailDomain": "udem.edu"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Loans": {
    "MaxActivePerRole": {
      "STUDENT": 3,
      "TEACHER": 5,
      "LIBRARIAN": 999,
      "ADMIN": 999
    },
    "DefaultDurationDaysPerRole": {
      "STUDENT": 7,
      "TEACHER": 21,
      "LIBRARIAN": 14,
      "ADMIN": 14
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
